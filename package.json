{
  "name": "niall-utils",
  "version": "1.5.0",
  "description": "Small collection of my web utilities",
  "author": "eniallator",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eniallator/Niall-Utils.git"
  },
  "homepage": "https://github.com/eniallator/Niall-Utils",
  "bugs": {
    "url": "https://github.com/eniallator/Niall-Utils/issues"
  },
  "keywords": [
    "utilities",
    "typescript",
    "web-utils"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./data": {
      "types": "./dist/data/index.d.ts",
      "import": "./dist/data/index.js"
    },
    "./encoding": {
      "types": "./dist/encoding/index.d.ts",
      "import": "./dist/encoding/index.js"
    },
    "./format": {
      "types": "./dist/format/index.d.ts",
      "import": "./dist/format/index.js"
    },
    "./functional": {
      "types": "./dist/functional/index.d.ts",
      "import": "./dist/functional/index.js"
    },
    "./math": {
      "types": "./dist/math/index.d.ts",
      "import": "./dist/math/index.js"
    },
    "./timing": {
      "types": "./dist/timing/index.d.ts",
      "import": "./dist/timing/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "import": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "yarn@4.17.0",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "build": "tsc",
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "findissues": "yarn typecheck && yarn lint",
    "bump-and-release": "./scripts/bump-and-release.sh",
    "release": "./scripts/release.sh",
    "publint": "publint run",
    "attw": "attw --pack .",
    "check-output": "./scripts/check-output.sh",
    "prepublish": "yarn typecheck && yarn lint && yarn build && yarn test && yarn publint && yarn check-output"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@vitest/coverage-v8": "4.1.6",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  },
  "resolutions": {
    "@arethetypeswrong/core@npm:0.18.2": "patch:@arethetypeswrong/core@npm%3A0.18.2#~/.yarn/patches/@arethetypeswrong-core-npm-0.18.2-d9050fce15.patch"
  }
}

{
  "author": "eniallator",
  "description": "Small collection of my web utilities",
  "engines": {
    "node": ">=25.4.0"
  },
  "homepage": "https://github.com/eniallator/Niall-Utils",
  "license": "MIT",
  "main": "dist/index.js",
  "name": "niall-utils",
  "packageManager": "yarn@4.14.1",
  "type": "module",
  "types": "dist/index.d.ts",
  "version": "1.1.0",
  "devDependencies": {
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^9.39.4",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/eslint": "^9.6.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-eslint-comments": "^3.2.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "strip-ansi": "^7.2.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  },
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "build": "tsc",
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "findissues": "yarn typecheck && yarn lint",
    "publish": "npm publish --access=public --tolerate-republish",
    "prepublish": "yarn typecheck && yarn lint && yarn build && yarn test",
    "bump-and-release": "powershell -ExecutionPolicy Bypass -File ./scripts/bump-and-release.ps1",
    "release": "powershell -ExecutionPolicy Bypass -File ./scripts/release.ps1"
  }
}

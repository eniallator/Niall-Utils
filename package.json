{
  "name": "niall-utils",
  "version": "1.3.0",
  "description": "Small collection of my web utilities",
  "author": "eniallator",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eniallator/Niall-Utils.git"
  },
  "homepage": "https://github.com/eniallator/Niall-Utils",
  "bugs": {
    "url": "https://github.com/eniallator/Niall-Utils/issues"
  },
  "keywords": [
    "utilities",
    "typescript",
    "web-utils"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "packageManager": "yarn@4.14.1",
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "build": "tsc",
    "lint": "eslint ./src",
    "typecheck": "tsc --noEmit",
    "findissues": "yarn typecheck && yarn lint",
    "publish": "npm publish --access=public",
    "bump-and-release": "./scripts/bump-and-release.sh",
    "release": "./scripts/release.sh",
    "publint": "publint run",
    "attw": "attw --pack .",
    "check-output": "./scripts/check-output.sh",
    "prepublish": "yarn typecheck && yarn lint && yarn build && yarn test && yarn publint && yarn check-output"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.3",
    "publint": "^0.3.21",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.4",
    "vitest": "^4.1.6"
  }
}
